# Arccos credentials (required)
ARCCOS_EMAIL=your_email@example.com
ARCCOS_PASSWORD=your_password

# Max rounds to pull per run. 0 = all. CLI: --max
ARCCOS_MAX_ROUNDS=0

# Database file path. CLI: --db
ARCCOS_DB_FILE=arccos.duckdb

# Visual Crossing weather API key (free tier: 1000 records/day)
# Sign up at https://www.visualcrossing.com/sign-up
VISUAL_CROSSING_API_KEY=

# GHIN credentials (optional - for official handicap/score data)
GHIN_EMAIL=
GHIN_PASSWORD=
