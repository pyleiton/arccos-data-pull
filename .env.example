# Arccos credentials (required)
ARCCOS_EMAIL=your_email@example.com
ARCCOS_PASSWORD=your_password

# User identity (required) — handle is the natural key in the users table.
# Use a short alphanumeric handle (e.g. "jason"). Display name is optional.
ARCCOS_USER_HANDLE=your_handle
ARCCOS_DISPLAY_NAME=Your Full Name

# Max rounds to pull per run. 0 = all. CLI: --max
ARCCOS_MAX_ROUNDS=0

# PostgreSQL connection (defaults shown)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=arccos

# Visual Crossing weather API key (free tier: 1000 records/day)
# Sign up at https://www.visualcrossing.com/sign-up
VISUAL_CROSSING_API_KEY=

# GHIN credentials (optional - for official handicap/score data)
GHIN_EMAIL=
GHIN_PASSWORD=
